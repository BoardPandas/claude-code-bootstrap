{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(git clone:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/check-commit-herestring.sh",
            "statusMessage": "Checking commit message syntax..."
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/pre-commit-changelog-reminder.sh",
            "statusMessage": "Checking changelog update..."
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/check-changelog-staged.sh",
            "statusMessage": "Verifying changelog is staged..."
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/pre-plan-kb-check.sh",
            "statusMessage": "Checking LL-G and BP knowledge bases..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/post-commit-kb-contribute.sh",
            "statusMessage": "Checking for knowledge base contributions..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\a'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\a'"
          }
        ]
      }
    ]
  },
  "plansDirectory": "tasks"
}
