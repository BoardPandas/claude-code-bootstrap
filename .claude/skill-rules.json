{
  "backend-dev-guidelines": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Universal guidelines for backend API development",
    "promptTriggers": {
      "keywords": [
        "backend",
        "api",
        "endpoint",
        "route",
        "handler",
        "controller",
        "database",
        "postgres",
        "mysql",
        "sql",
        "query",
        "server",
        "middleware"
      ],
      "intentPatterns": [
        "(create|add|build|implement).*(route|endpoint|api|handler|controller)",
        "(fix|debug|resolve).*(backend|api|server|endpoint)",
        "(database|db|postgres|mysql|sql).*(query|table|schema)",
        "(add|create).*(table|column|migration)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/**/*.{ts,js,py,go,rb,rs,java,cs}",
        "**/routes/**/*",
        "**/handlers/**/*",
        "**/api/**/*",
        "database/**/*.sql"
      ],
      "contentPatterns": [
        "app\\.(get|post|put|delete|patch)",
        "router\\.",
        "@app\\.(get|post|put|delete|patch)",
        "func.*Handler",
        "http\\.HandleFunc",
        "async.*req.*res",
        "def (get|post|put|delete|patch)"
      ]
    }
  },

  "frontend-dev-guidelines": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Universal guidelines for frontend/UI development",
    "promptTriggers": {
      "keywords": [
        "frontend",
        "component",
        "page",
        "ui",
        "interface",
        "layout",
        "form",
        "dashboard"
      ],
      "intentPatterns": [
        "(create|add|build).*(component|page|ui|interface|view)",
        "(style|design|layout)",
        "(fix|debug).*(frontend|dashboard|ui|component)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/*.{tsx,jsx,vue,svelte}",
        "**/components/**/*",
        "**/pages/**/*",
        "**/views/**/*",
        "**/app/**/*.{tsx,jsx}"
      ],
      "contentPatterns": [
        "import.*from ['\"]react['\"]",
        "export default function",
        "useState|useEffect|useContext",
        "<template>",
        "<script setup>"
      ]
    }
  },

  "production-principles": {
    "type": "quality",
    "enforcement": "suggest",
    "priority": "critical",
    "description": "Enforce MVP/prototype principles - simplicity over complexity",
    "promptTriggers": {
      "keywords": [
        "architecture",
        "refactor",
        "abstraction",
        "service layer",
        "factory",
        "repository pattern",
        "over-engineering"
      ],
      "intentPatterns": [
        "(create|add|implement).*(service|factory|repository)",
        "(refactor|redesign|restructure)",
        "(abstract|generalize)",
        "dependency.?injection",
        "design.?pattern"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/**/*.{ts,js,py,go,rb,rs,java,cs}"
      ],
      "contentPatterns": [
        "class.*Service",
        "class.*Factory",
        "class.*Repository",
        "abstract class"
      ]
    }
  },

  "tdd-workflow": {
    "type": "quality",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Test-Driven Development workflow and testing guidelines",
    "promptTriggers": {
      "keywords": [
        "test",
        "testing",
        "tdd",
        "spec",
        "unit test",
        "integration test"
      ],
      "intentPatterns": [
        "(write|add|create).*(test|spec)",
        "(test|testing).*(feature|function|endpoint)",
        "tdd"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/*.test.{ts,js,tsx,jsx}",
        "**/*.spec.{ts,js,tsx,jsx}",
        "**/test/**/*",
        "**/tests/**/*",
        "**/*_test.go",
        "**/test_*.py",
        "**/*_test.py"
      ],
      "contentPatterns": [
        "describe\\(",
        "it\\(",
        "test\\(",
        "expect\\(",
        "def test_",
        "func Test",
        "assert",
        "pytest"
      ]
    }
  },

  "security-practices": {
    "type": "quality",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Security best practices and authentication",
    "promptTriggers": {
      "keywords": [
        "security",
        "authentication",
        "authorization",
        "auth",
        "jwt",
        "token",
        "password",
        "secret",
        "api key"
      ],
      "intentPatterns": [
        "(auth|authentication|authorization)",
        "(jwt|token).*(verify|validate|generate)",
        "security",
        "(api.?key|secret)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/*auth*.{ts,js,py,go,rb}",
        "**/*security*.{ts,js,py,go,rb}",
        "**/middleware/**/*"
      ],
      "contentPatterns": [
        "jwt\\.",
        "bcrypt",
        "Authorization.*Bearer",
        "authenticate",
        "password_hash"
      ]
    }
  },

  "skill-developer": {
    "type": "quality",
    "enforcement": "suggest",
    "priority": "low",
    "description": "Guide for creating and maintaining Claude Code skills",
    "promptTriggers": {
      "keywords": [
        "create skill",
        "new skill",
        "skill development",
        "skill-rules",
        "auto-activation"
      ],
      "intentPatterns": [
        "(create|add|build|write).*(skill|claude.*skill)",
        "(skill|skills).*(development|creation|guide)",
        "auto.?activation",
        "skill.?rules"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        ".claude/skills/**/*.md",
        ".claude/skill-rules.json"
      ],
      "contentPatterns": [
        "# .*Skill",
        "## Core Principles",
        "promptTriggers",
        "fileTriggers"
      ]
    }
  }
}
